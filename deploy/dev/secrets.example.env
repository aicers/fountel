# fountel dev — SECRET SCHEMA (template, NON-SECRET placeholders).
#
# This committed template documents exactly which secrets the dev stack needs.
# It is NEVER read by the stack. The real values live ENCRYPTED in
# `secrets.enc.env` (committed, sops) and are decrypted at deploy time into
# `secrets/misp.secrets.env` (git-ignored). See docs/secrets.md.
#
# `./bin/secrets-init.sh` generates strong random values for every key below
# and writes the encrypted `secrets.enc.env`. Do NOT copy these placeholders
# into a running stack.

# MariaDB application user password (misp-core <-> db).
MYSQL_PASSWORD=REPLACE_ME

# MariaDB root password (db initialization / admin).
MYSQL_ROOT_PASSWORD=REPLACE_ME

# Redis/Valkey AUTH password (misp-core <-> redis).
REDIS_PASSWORD=REPLACE_ME

# MISP admin (site_admin) account password for ADMIN_EMAIL.
ADMIN_PASSWORD=REPLACE_ME

# MISP security.salt — used to hash credentials. Changing it invalidates all
# existing user passwords and API keys, so it is set once and kept stable.
SALT=REPLACE_ME

# Passphrase for the instance GnuPG key. MISP generates the key from this on
# first boot and stores it in the misp_gnupg Docker named volume.
GPG_PASSPHRASE=REPLACE_ME

# Fixed admin REST API key (40 hex chars). Pinning it makes the idempotent
# bootstrap (taxonomy enable) reproducible instead of depending on an
# auto-generated key. Treat as the deferred read/admin REST credential.
ADMIN_KEY=REPLACE_ME

# Outbound SMTP relay password. Empty in dev (no real mail relay).
SMARTHOST_PASSWORD=
