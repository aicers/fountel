# fountel dev — compose interpolation variables (NON-SECRET).
#
# Copy to `.env` (which is git-ignored) and adjust if needed:
#     cp .env.example .env
#
# Secrets do NOT live here. They are generated locally by ./bin/secrets-init.sh
# into the git-ignored `secrets/misp.secrets.env` (see docs/secrets.md).
# Image tags are pinned in docker-compose.yml itself, not here, so the pin is
# unambiguous and lives in version control.

# Host ports. Container always listens on 80/443; these are the host-side maps.
# Change these (not the container side) if a port is already in use.
CORE_HTTP_PORT=8080
CORE_HTTPS_PORT=8443

# Advertised base URL. Must include the HTTPS host port above.
BASE_URL=https://localhost:8443

# Non-secret database identity. The password is a secret (see secrets.example.env).
MYSQL_USER=misp
MYSQL_DATABASE=misp

# Admin bootstrap identity. The admin password is a secret.
ADMIN_EMAIL=admin@fountel.local
ADMIN_ORG=fountel

# Timezone applied to every container.
TZ=UTC
