# ---------------------------------------------------------------------------
# Secrets — NEVER commit secret material.
#
# Dev secrets are generated locally at bring-up into a per-environment
# `secrets/` directory and must stay out of version control. Nothing secret is
# committed.
# ---------------------------------------------------------------------------
secrets/
*.secrets.env

# Local compose interpolation env (the committed template is .env.example).
.env
deploy/*/.env

# ---------------------------------------------------------------------------
# MISP runtime state lives in Docker NAMED VOLUMES (see docker-compose.yml),
# not host directories, so there is nothing to ignore here. These entries
# guard against accidentally committing host dirs if a bind mount is ever
# reintroduced.
# ---------------------------------------------------------------------------
deploy/*/configs/
deploy/*/logs/
deploy/*/files/
deploy/*/ssl/
deploy/*/gnupg/
deploy/*/custom/

# ---------------------------------------------------------------------------
# OS / editor noise
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
